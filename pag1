                </div>

                <!-- Status Bar -->
                <div class="bg-[#020a07] glow-border rounded-full px-4 py-2 flex justify-between items-center text-xs font-semibold">
                    <span class="flex items-center gap-2 text-[#e2e8f0]">
                        <span class="dot-online"></span> <span id="online-count">22</span> online agora
                    </span>
                    <span class="text-[#e2e8f0]">
                        🎲 <span id="daily-count">1.2k</span> palpites hoje
