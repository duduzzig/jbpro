                    </div>
                </div>

                <!-- Action Buttons -->
                <button id="gerarBtn" class="action-btn-green w-full py-3.5 rounded-xl font-bold text-sm flex justify-center items-center gap-2">
                    ✨ GERAR MILHARES DA SORTE ✨
                </button>
                
                <button onclick="window.open('https://apostanacional.net/convite/W5IAX', '_blank')" class="action-btn-red w-full py-3.5 rounded-xl font-bold text-sm flex justify-center items-center gap-2">
