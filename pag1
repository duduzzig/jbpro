                        <button onclick="setLoteria('todas')" id="lot-todas" class="pill-btn active px-4 py-1.5 rounded-full text-xs font-bold">🇧🇷 Brasil (Geral)</button>
                        <button onclick="setLoteria('rio')" id="lot-rio" class="pill-btn px-4 py-1.5 rounded-full text-xs font-bold">🏖️ Rio (PT)</button>
                        <button onclick="setLoteria('sp')" id="lot-sp" class="pill-btn px-4 py-1.5 rounded-full text-xs font-bold">🏙️ São Paulo</button>
                        <button onclick="setLoteria('look')" id="lot-look" class="pill-btn px-4 py-1.5 rounded-full text-xs font-bold">🤠 Look / Goiás</button>
                        <button onclick="setLoteria('lotep')" id="lot-lotep" class="pill-btn px-4 py-1.5 rounded-full text-xs font-bold">☀️ Lotep PB</button>
                        <button onclick="setLoteria('bahia')" id="lot-bahia" class="pill-btn px-4 py-1.5 rounded-full text-xs font-bold">🌴 Bahia</button>
                        <button onclick="setLoteria('nacional')" id="lot-nacional" class="pill-btn px-4 py-1.5 rounded-full text-xs font-bold">⭐ Nacional</button>
                        <button onclick="setLoteria('lotece')" id="lot-lotece" class="pill-btn px-4 py-1.5 rounded-full text-xs font-bold">🌊 Lotece</button>
