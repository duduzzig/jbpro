                    <div class="flex items-center bg-[#05140d] border border-[#00331c] rounded-full p-1">
                        <button onclick="changeQtd(-1)" class="w-8 h-8 rounded-full text-[#00ff88] font-bold text-lg hover:bg-[#00ff88]/10">−</button>
                        <input type="number" id="quantidade" value="5" readonly class="w-8 text-center bg-transparent border-none text-[#00ff88] font-bold text-sm outline-none">
