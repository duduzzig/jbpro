                </div>

                <!-- Sub-Filtros -->
                <div id="sub-filters" class="flex gap-2 overflow-x-auto no-scrollbar pb-1 -mx-1 px-1">
                    <button onclick="setFilter('todos')" id="filt-todos" class="pill-btn active px-4 py-1.5 rounded-full text-xs font-bold">Todos os grupos</button>
                    <button onclick="setFilter('quentes')" id="filt-quentes" class="pill-btn px-4 py-1.5 rounded-full text-xs font-bold">🔥 Quentes</button>
