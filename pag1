                <div class="h-px w-full bg-[#00331c] my-1"></div>

                <!-- Modos Principais -->
                <div class="flex flex-col gap-2">
                    <span class="text-[11px] font-bold text-[#88aa99] flex items-center gap-1 uppercase tracking-wider">🎯 2. Modo de Geração</span>
                    <div class="flex gap-2 w-full">
                        <button onclick="setMode('aleatorio')" id="mode-aleatorio" class="pill-btn active flex-1 py-2 rounded-xl text-xs font-bold">
                            🎲 Aleatório
                        </button>
                        <button onclick="setMode('bicho')" id="mode-bicho" class="pill-btn flex-1 py-2 rounded-xl text-xs font-bold">
                            🐾 Por Bicho
