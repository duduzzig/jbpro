                        🍀 Seus palpites premiados
                    </div>
                    
                    <div id="palpitesWrapper" class="min-h-[80px] flex flex-wrap gap-2 items-center justify-center mb-4">
                        <span class="text-[#475569] text-xs">Clique em "GERAR" para ver seus milhares</span>
                    </div>

                    <button id="copiarBtn" class="w-full bg-[#05140d] hover:bg-[#00ff88]/10 border border-[#00331c] hover:border-[#00ff88]/50 text-[#88aa99] hover:text-[#00ff88] py-2.5 rounded-lg text-[11px] font-bold transition-all flex items-center justify-center gap-2">
                        📋 COPIAR TODOS OS PALPITES
                    </button>
                </div>
            </div>

            <!-- Golden Banner -->
            <div class="gold-banner mt-4 rounded-2xl p-4 flex justify-between items-center">
                <div>
                    <div class="text-[10px] font-bold uppercase tracking-wider opacity-80 mb-1 flex items-center gap-1">
                        ⭐ Número da Sorte do Dia
                    </div>
                    <div id="numero-dia" class="text-3xl font-black tracking-widest">6148</div>
                </div>
                <button onclick="gerarNumeroDia()" class="bg-black/10 hover:bg-black/20 border border-black/20 px-3 py-1.5 rounded-full text-xs font-bold transition-colors flex items-center gap-1">
