<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <meta name="description" content="Gerador de Milhares PRO - Análise e Palpites da Sorte">
    <title>Painel PRO | Gerador Neon</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <!-- Chosen Palette: Deep Matrix Green (#020a07) & Neon Mint (#00ff88) with Golden Accents -->
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800;900&display=swap');

        body {
            background-color: #020a07; /* Very dark green/black */
            font-family: 'Inter', system-ui, sans-serif;
            color: #e2e8f0;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            padding: 10px;
        }

        /* Custom Scrollbar for dark theme */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #020a07; }
        ::-webkit-scrollbar-thumb { background: #004d2a; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #00ff88; }

        /* Neon Glow Effects */
        .glow-border {
            border: 1px solid rgba(0, 255, 136, 0.3);
            box-shadow: 0 0 15px rgba(0, 255, 136, 0.05);
        }
        .glow-border-active {
            border: 1px solid #00ff88;
            box-shadow: 0 0 10px rgba(0, 255, 136, 0.2), inset 0 0 10px rgba(0, 255, 136, 0.1);
        }
        .text-neon {
            color: #00ff88;
            text-shadow: 0 0 8px rgba(0, 255, 136, 0.4);
        }

        /* Toggle Buttons / Pills */
        .pill-btn {
            background: #04140d;
            border: 1px solid #00331c;
            color: #88aa99;
            transition: all 0.2s;
            white-space: nowrap;
        }
        .pill-btn.active {
            background: rgba(0, 255, 136, 0.1);
            border-color: #00ff88;
            color: #00ff88;
            box-shadow: inset 0 0 10px rgba(0, 255, 136, 0.1);
        }
        
        /* Action Buttons */
        .action-btn-green {
            background: #04140d;
            border: 1px solid #004d2a;
            color: #00ff88;
            transition: all 0.2s;
        }
        .action-btn-green:active {
            transform: scale(0.98);
            background: rgba(0, 255, 136, 0.1);
            border-color: #00ff88;
        }
        .action-btn-green:disabled {
            opacity: 0.7;
            cursor: not-allowed;
            transform: none;
        }

        .action-btn-red {
            background: #04140d;
            border: 1px solid #4d001a;
            color: #ff3366;
            transition: all 0.2s;
        }
        .action-btn-red:active {
            transform: scale(0.98);
            background: rgba(255, 51, 102, 0.1);
            border-color: #ff3366;
        }

        /* Golden Banner */
        .gold-banner {
            background: linear-gradient(135deg, #fbbf24, #d97706);
            color: #451a03;
            box-shadow: 0 10px 25px rgba(217, 119, 6, 0.2);
        }

        /* Input specific */
        .neon-input {
            background: #020a07;
            border: 1px solid #00331c;
            color: #00ff88;
            transition: all 0.2s;
        }
        .neon-input:focus {
            outline: none;
            border-color: #00ff88;
            box-shadow: 0 0 10px rgba(0, 255, 136, 0.1);
        }

        /* Animations */
        @keyframes pulse-green {
            0%, 100% { opacity: 1; transform: scale(1); box-shadow: 0 0 5px #00ff88; }
            50% { opacity: 0.5; transform: scale(1.2); box-shadow: 0 0 10px #00ff88; }
        }
        .dot-online {
            width: 8px; height: 8px; background: #00ff88; border-radius: 50%;
            display: inline-block; animation: pulse-green 1.5s infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
        .spinner {
            width: 16px; height: 16px; border: 2px solid #00ff88; border-top-color: transparent;
            border-radius: 50%; animation: spin 0.8s linear infinite; display: inline-block;
        }
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade { animation: fadeUp 0.3s ease-out forwards; }

        /* Hide scrollbar for pills container but allow scroll */
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

        /* Chart constraints */
        .chart-container { position: relative; width: 100%; height: 250px; }
    </style>
</head>
<body class="items-center sm:py-6">

    <div class="w-full max-w-[500px] flex flex-col gap-4">
        
        <!-- Navbar -->
        <nav class="bg-[#05140d] glow-border rounded-full p-2 flex justify-between items-center px-4 w-full">
            <div class="font-extrabold text-sm text-[#00ff88] hidden sm:block mr-2">JB PRO</div>
