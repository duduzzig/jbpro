        </main>

        <!-- SEC: ESTATÍSTICAS -->
        <main id="sec-estatisticas" class="w-full hidden animate-fade">
            <div class="bg-[#05140d] glow-border rounded-3xl p-5 flex flex-col gap-6">
                <div>
                    <h2 class="text-lg font-bold text-[#00ff88] mb-1">🔥 Mais Atrasados</h2>
                    <p class="text-[11px] text-[#88aa99] mb-3" id="stats-desc">Dias sem sair no 1º prêmio. (Dados ajustáveis por Extração na aba Gerar)</p>
                    <div class="bg-[#020a07] border border-[#00331c] rounded-xl p-3">
                        <div class="chart-container"><canvas id="chartAtrasados"></canvas></div>
                    </div>
                </div>
                <div>
                    <h2 class="text-lg font-bold text-[#00ff88] mb-1">📈 Grupos Quentes</h2>
                    <p class="text-[11px] text-[#88aa99] mb-3">Frequência dos últimos 30 sorteios.</p>
                    <div class="bg-[#020a07] border border-[#00331c] rounded-xl p-3">
                        <div class="chart-container"><canvas id="chartQuentes"></canvas></div>
                    </div>
                </div>
            </div>
        </main>

        <!-- SEC: TABELA -->
        <main id="sec-tabela" class="w-full hidden animate-fade">
            <div class="bg-[#05140d] glow-border rounded-3xl p-5">
                <h2 class="text-lg font-bold text-[#00ff88] mb-1">📜 Tabela Oficial</h2>
                <p class="text-[11px] text-[#88aa99] mb-4">Guia rápido dos 25 grupos e dezenas.</p>
                <div id="grid-tabela-ref" class="grid grid-cols-2 sm:grid-cols-3 gap-2">
                    <!-- Populated by JS -->
                </div>
            </div>
        </main>

    </div>

    <!-- Toast Notification -->
    <div id="toast" class="fixed bottom-5 left-1/2 -translate-x-1/2 bg-[#00ff88] text-[#020a07] px-4 py-2 rounded-full font-bold text-xs opacity-0 transition-opacity duration-300 pointer-events-none z-50 shadow-[0_0_15px_rgba(0,255,136,0.5)] flex items-center gap-2 w-max max-w-[90vw]">
        <span>✅</span> <span id="toast-msg">Sucesso!</span>
    </div>

    <script>
        // --- DATA ---
        const tabelaBichos = [
            { grupo: 1, nome: "Avestruz", emoji: "🦅", dezenas: ["01", "02", "03", "04"] },
            { grupo: 2, nome: "Águia", emoji: "🦅", dezenas: ["05", "06", "07", "08"] },
            { grupo: 3, nome: "Burro", emoji: "🐴", dezenas: ["09", "10", "11", "12"] },
            { grupo: 4, nome: "Borboleta", emoji: "🦋", dezenas: ["13", "14", "15", "16"] },
            { grupo: 5, nome: "Cachorro", emoji: "🐶", dezenas: ["17", "18", "19", "20"] },
            { grupo: 6, nome: "Cabra", emoji: "🐐", dezenas: ["21", "22", "23", "24"] },
            { grupo: 7, nome: "Carneiro", emoji: "🐏", dezenas: ["25", "26", "27", "28"] },
            { grupo: 8, nome: "Camelo", emoji: "🐫", dezenas: ["29", "30", "31", "32"] },
            { grupo: 9, nome: "Cobra", emoji: "🐍", dezenas: ["33", "34", "35", "36"] },
            { grupo: 10, nome: "Coelho", emoji: "🐇", dezenas: ["37", "38", "39", "40"] },
            { grupo: 11, nome: "Cavalo", emoji: "🐎", dezenas: ["41", "42", "43", "44"] },
            { grupo: 12, nome: "Elefante", emoji: "🐘", dezenas: ["45", "46", "47", "48"] },
            { grupo: 13, nome: "Galo", emoji: "🐓", dezenas: ["49", "50", "51", "52"] },
            { grupo: 14, nome: "Gato", emoji: "🐈", dezenas: ["53", "54", "55", "56"] },
            { grupo: 15, nome: "Jacaré", emoji: "🐊", dezenas: ["57", "58", "59", "60"] },
            { grupo: 16, nome: "Leão", emoji: "🦁", dezenas: ["61", "62", "63", "64"] },
            { grupo: 17, nome: "Macaco", emoji: "🐒", dezenas: ["65", "66", "67", "68"] },
            { grupo: 18, nome: "Porco", emoji: "🐷", dezenas: ["69", "70", "71", "72"] },
            { grupo: 19, nome: "Pavão", emoji: "🦚", dezenas: ["73", "74", "75", "76"] },
            { grupo: 20, nome: "Peru", emoji: "🦃", dezenas: ["77", "78", "79", "80"] },
            { grupo: 21, nome: "Touro", emoji: "🐂", dezenas: ["81", "82", "83", "84"] },
            { grupo: 22, nome: "Tigre", emoji: "🐅", dezenas: ["85", "86", "87", "88"] },
            { grupo: 23, nome: "Urso", emoji: "🐻", dezenas: ["89", "90", "91", "92"] },
            { grupo: 24, nome: "Veado", emoji: "🦌", dezenas: ["93", "94", "95", "96"] },
            { grupo: 25, nome: "Vaca", emoji: "🐄", dezenas: ["97", "98", "99", "00"] }
        ];

        const gruposAtrasados = [3, 15, 19, 2, 8];
        const gruposQuentes = [5, 14, 21, 25, 1];

        const nomesLoterias = {
            'todas': 'Nacional / Geral',
            'rio': 'PT-Rio',
            'sp': 'São Paulo',
            'look': 'Look Goiás',
            'lotep': 'Lotep PB',
            'bahia': 'Bahia',
            'nacional': 'Nacional',
            'lotece': 'Lotece'
        };

        // --- STATE ---
        let loteriaSelecionada = 'todas';
        let genMode = 'aleatorio'; 
        let genFilter = 'todos'; 
        let bichoSelecionadoId = null;
        let ultimosPalpites = [];
        let chartsInit = false;

        // --- UI UPDATES ---
        function changeTab(tab) {
            ['gerador', 'estatisticas', 'tabela'].forEach(t => {
                document.getElementById(`sec-${t}`).classList.add('hidden');
                document.getElementById(`tab-${t}`).classList.remove('active', 'glow-border-active');
            });
            document.getElementById(`sec-${tab}`).classList.remove('hidden');
            document.getElementById(`tab-${tab}`).classList.add('active', 'glow-border-active');
            
            if (tab === 'estatisticas') {
                document.getElementById('stats-desc').innerText = `Dias sem sair no 1º prêmio na extração: ${nomesLoterias[loteriaSelecionada]}.`;
                if (!chartsInit) {
                    renderCharts(); chartsInit = true;
                }
            }
            if (tab === 'tabela' && document.getElementById('grid-tabela-ref').children.length === 0) {
                renderTabelaCompleta();
            }
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function setLoteria(id) {
            loteriaSelecionada = id;
            ['todas', 'rio', 'sp', 'look', 'lotep', 'bahia', 'nacional', 'lotece'].forEach(l => {
                document.getElementById(`lot-${l}`).classList.remove('active');
            });
            document.getElementById(`lot-${id}`).classList.add('active');
        }

        function setMode(mode) {
            genMode = mode;
            ['aleatorio', 'bicho', 'atrasados'].forEach(m => {
                document.getElementById(`mode-${m}`).classList.remove('active', 'glow-border-active');
            });
            document.getElementById(`mode-${mode}`).classList.add('active', 'glow-border-active');

            const subFilters = document.getElementById('sub-filters');
            const animalGrid = document.getElementById('animal-grid-container');

            if (mode === 'bicho') {
                subFilters.classList.add('hidden');
                animalGrid.classList.remove('hidden');
                renderAnimalGrid();
            } else if (mode === 'atrasados') {
                subFilters.classList.add('hidden');
                animalGrid.classList.add('hidden');
                genFilter = 'atrasados'; 
            } else { 
                subFilters.classList.remove('hidden');
                animalGrid.classList.add('hidden');
                setFilter('todos'); 
            }
        }

        function setFilter(filter) {
            if (genMode !== 'aleatorio') return;
            genFilter = filter;
            ['todos', 'quentes', 'atrasados', 'pares', 'impares'].forEach(f => {
                document.getElementById(`filt-${f}`).classList.remove('active');
            });
            document.getElementById(`filt-${filter}`).classList.add('active');
        }

        function changeQtd(val) {
            const el = document.getElementById('quantidade');
            let q = parseInt(el.value) + val;
            if (q >= 1 && q <= 30) el.value = q;
        }

        function showToast(msg) {
            const toast = document.getElementById('toast');
            document.getElementById('toast-msg').innerText = msg;
            toast.style.opacity = '1';
            setTimeout(() => toast.style.opacity = '0', 2500);
        }

        // --- GENERATION LOGIC ---
        function getGrupo(milhar) {
            const dz = parseInt(milhar.slice(-2));
            return dz === 0 ? 25 : Math.ceil(dz / 4);
        }

        function gerarMilharBase() {
            return Math.floor(Math.random() * 10000).toString().padStart(4, '0');
        }

        function isValidByFilter(milhar, filter, mode, bichoId) {
            const g = getGrupo(milhar);
            if (mode === 'bicho') return g === bichoId;
            if (mode === 'atrasados') return gruposAtrasados.includes(g);
            if (filter === 'todos') return true;
            if (filter === 'quentes') return gruposQuentes.includes(g);
            if (filter === 'atrasados') return gruposAtrasados.includes(g);
            if (filter === 'pares') return g % 2 === 0;
            if (filter === 'impares') return g % 2 !== 0;
            return true;
        }

        async function processoGerar() {
            const btn = document.getElementById('gerarBtn');
            const wrap = document.getElementById('palpitesWrapper');
            const qtd = parseInt(document.getElementById('quantidade').value);
            
            if (genMode === 'bicho' && !bichoSelecionadoId) {
                showToast("Selecione um bicho na lista primeiro!");
                return;
            }

            btn.innerHTML = `<span class="spinner"></span> GERANDO...`;
            btn.disabled = true;
            wrap.innerHTML = `<span class="text-[#88aa99] text-xs animate-pulse">Cruzando dados para ${nomesLoterias[loteriaSelecionada]}...</span>`;

            await new Promise(r => setTimeout(r, 1000)); // Simulando busca na loteria específica

            const palpites = [];
            let tentativas = 0;
            while(palpites.length < qtd && tentativas < 5000) {
                const m = gerarMilharBase();
                if(isValidByFilter(m, genFilter, genMode, bichoSelecionadoId)) {
                    if(!palpites.includes(m)) palpites.push(m);
                }
                tentativas++;
            }
            
            ultimosPalpites = palpites;
            
            wrap.innerHTML = '';
            palpites.forEach((p, i) => {
                setTimeout(() => {
                    const chip = document.createElement('div');
                    chip.className = 'bg-[#00ff88]/10 border border-[#00ff88]/50 text-[#00ff88] px-3 py-1.5 rounded-lg font-mono font-bold text-lg animate-fade shadow-[0_0_10px_rgba(0,255,136,0.1)]';
                    chip.innerText = p;
                    wrap.appendChild(chip);
                }, i * 50);
            });

            let c = parseFloat(document.getElementById('daily-count').innerText);
            document.getElementById('daily-count').innerText = (c + 0.1).toFixed(1) + 'k';

            setTimeout(() => {
                btn.innerHTML = `✨ GERAR MILHARES DA SORTE ✨`;
                btn.disabled = false;
                showToast(`Milhares otimizadas para ${nomesLoterias[loteriaSelecionada]}!`);
            }, palpites.length * 50 + 200);
        }

        // --- RENDERERS ---
        function renderAnimalGrid() {
            const grid = document.getElementById('animaisGrid');
            if (grid.children.length > 0 && !bichoSelecionadoId) return; 
            grid.innerHTML = '';
            tabelaBichos.forEach(b => {
                const isSel = bichoSelecionadoId === b.grupo;
                const div = document.createElement('div');
                div.className = `flex flex-col items-center justify-center p-2 rounded-xl cursor-pointer text-[10px] font-bold border transition-colors ${isSel ? 'bg-[#00ff88]/20 border-[#00ff88] text-[#00ff88]' : 'bg-[#020a07] border-[#00331c] text-[#88aa99] hover:border-[#00ff88]/50'}`;
                div.innerHTML = `<span class="text-lg mb-0.5">${b.emoji}</span><span class="truncate w-full text-center">${b.nome}</span>`;
                div.onclick = () => {
                    bichoSelecionadoId = b.grupo;
                    renderAnimalGrid();
                };
                grid.appendChild(div);
            });
        }

        function renderTabelaCompleta() {
            const grid = document.getElementById('grid-tabela-ref');
            tabelaBichos.forEach(b => {
                const div = document.createElement('div');
                div.className = 'bg-[#020a07] border border-[#00331c] p-2 rounded-xl flex flex-col items-center';
                div.innerHTML = `
                    <div class="flex justify-between w-full text-[10px] text-[#88aa99] mb-1">
                        <span>G${b.grupo.toString().padStart(2,'0')}</span> <span>${b.emoji}</span>
                    </div>
                    <div class="font-bold text-[#e2e8f0] text-xs uppercase mb-1">${b.nome}</div>
                    <div class="grid grid-cols-2 gap-1 w-full text-[10px] font-mono text-[#00ff88] text-center">
                        ${b.dezenas.map(d => `<span class="bg-[#05140d] rounded">${d}</span>`).join('')}
                    </div>
                `;
                grid.appendChild(div);
            });
        }

        function gerarNumeroDia() {
            const num = Math.floor(Math.random() * 10000).toString().padStart(4, '0');
            const el = document.getElementById('numero-dia');
            el.classList.remove('animate-fade');
            void el.offsetWidth; 
            el.innerText = num;
            el.classList.add('animate-fade');
        }

        function renderCharts() {
            Chart.defaults.color = '#88aa99';
            Chart.defaults.font.family = "'Inter', sans-serif";

            new Chart(document.getElementById('chartAtrasados'), {
                type: 'bar',
                data: {
                    labels: ['Burro 🐴', 'Jacaré 🐊', 'Pavão 🦚', 'Águia 🦅', 'Camelo 🐪'],
                    datasets: [{
                        data: [42, 35, 28, 25, 21],
                        backgroundColor: '#00ff88',
                        borderRadius: 4,
                        barPercentage: 0.6
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { border: {display: false}, grid: {color: '#00331c'} },
                        x: { border: {display: false}, grid: {display: false} }
                    }
                }
            });

            new Chart(document.getElementById('chartQuentes'), {
                type: 'doughnut',
                data: {
                    labels: ['Cachorro', 'Gato', 'Touro', 'Vaca', 'Outros'],
                    datasets: [{
                        data: [15, 12, 10, 8, 55],
                        backgroundColor: ['#00ff88', '#00cc66', '#00994d', '#006633', '#020a07'],
                        borderColor: '#05140d',
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false, cutout: '75%',
                    plugins: { legend: { position: 'right', labels: {boxWidth: 10, color: '#e2e8f0'} } }
                }
            });
        }

        // --- EVENT LISTENERS ---
        document.getElementById('gerarBtn').addEventListener('click', processoGerar);
        
        document.getElementById('copiarBtn').addEventListener('click', async () => {
            if (!ultimosPalpites.length) return showToast("Gere palpites primeiro!");
            try {
                await navigator.clipboard.writeText(ultimosPalpites.join(', '));
                showToast("Copiado para a área de transferência!");
            } catch (e) {
                showToast("Erro ao copiar.");
            }
        });

        setInterval(() => {
            const el = document.getElementById('online-count');
            el.innerText = Math.floor(Math.random() * 20) + 15;
        }, 5000);

        // Init
        gerarNumeroDia();

    </script>
</body>
</html>
